    <!-- GET /metadata/tables -->
    <flow name="get:\metadata\tables:clouderby-api-config">
        <flow-ref name="validate-session"/>
        <set-variable variableName="tablePattern" value="#[attributes.queryParams.tablePattern default '%']"/>
        <java:invoke-static class="com.muledev.server.SqlExecutor" method="executeMetadataQuery(String, String, List)">
            <java:args>#[{
                sessionId: vars.sessionId,
                sql: "SELECT T.TABLENAME AS NAME, CASE T.TABLETYPE WHEN 'T' THEN 'TABLE' WHEN 'V' THEN 'VIEW' ELSE T.TABLETYPE END AS TYPE FROM SYS.SYSTABLES T JOIN SYS.SYSSCHEMAS S ON T.SCHEMAID = S.SCHEMAID WHERE S.SCHEMANAME = 'APP' AND T.TABLETYPE IN ('T', 'V') AND T.TABLENAME LIKE ? ORDER BY T.TABLENAME",
                params: [vars.tablePattern]
            }]</java:args>
        </java:invoke-static>
        <ee:transform doc:name="Build tables response">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    tables: payload map (row) -> {
        name: row.NAME,
        "type": row."TYPE"
    },
    count: sizeOf(payload)
}]]></ee:set-payload>
            </ee:message>
        </ee:transform>
        <error-handler ref="api-error-handler"/>
    </flow>

    <!-- GET /metadata/columns -->
    <flow name="get:\metadata\columns:clouderby-api-config">
        <flow-ref name="validate-session"/>
        <set-variable variableName="tablePattern" value="#[attributes.queryParams.tablePattern default '%']"/>
        <set-variable variableName="columnPattern" value="#[attributes.queryParams.columnPattern default '%']"/>
        <java:invoke-static class="com.muledev.server.SqlExecutor" method="executeMetadataQuery(String, String, List)">
            <java:args>#[{
                sessionId: vars.sessionId,
                sql: "SELECT T.TABLENAME, C.COLUMNNAME, CAST(C.COLUMNDATATYPE AS VARCHAR(128)) AS TYPE_INFO, C.COLUMNNUMBER, C.COLUMNDEFAULTID, CASE WHEN C.AUTOINCREMENTVALUE IS NOT NULL THEN 'YES' ELSE 'NO' END AS IS_AUTOINCREMENT FROM SYS.SYSCOLUMNS C JOIN SYS.SYSTABLES T ON C.REFERENCEID = T.TABLEID JOIN SYS.SYSSCHEMAS S ON T.SCHEMAID = S.SCHEMAID WHERE S.SCHEMANAME = 'APP' AND T.TABLETYPE = 'T' AND T.TABLENAME LIKE ? AND C.COLUMNNAME LIKE ? ORDER BY T.TABLENAME, C.COLUMNNUMBER",
                params: [vars.tablePattern, vars.columnPattern]
            }]</java:args>
        </java:invoke-static>
        <ee:transform doc:name="Build columns response">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
fun parseTypeInfo(ti) = do {
    var cleaned = upper(trim((ti splitBy " GENERATED")[0]))
    var isNotNull = cleaned contains "NOT NULL"
    var typeStr = trim((cleaned splitBy " NOT NULL")[0])
    var parts = typeStr splitBy "("
    var typeName = trim(parts[0])
    var sizeStr = if (sizeOf(parts) > 1) trim((parts[1] splitBy ")")[0]) else ""
    var sizeParts = sizeStr splitBy ","
    var colSize = if (sizeStr != "") (trim(sizeParts[0]) as Number default 0) else (typeName match {
        case "INTEGER" -> 10
        case "BIGINT" -> 19
        case "SMALLINT" -> 5
        case "DOUBLE" -> 15
        case "REAL" -> 7
        case "DECIMAL" -> 31
        case "DATE" -> 10
        case "TIMESTAMP" -> 29
        case "BOOLEAN" -> 1
        else -> 255
    })
    ---
    {typeName: typeName, colSize: colSize, nullable: if (isNotNull) 0 else 1}
}
fun mapDataType(tn) = tn match {
    case "INTEGER" -> 4
    case "BIGINT" -> -5
    case "SMALLINT" -> 5
    case "DOUBLE" -> 8
    case "REAL" -> 7
    case "FLOAT" -> 6
    case "DECIMAL" -> 3
    case "NUMERIC" -> 2
    case "VARCHAR" -> 12
    case "CHAR" -> 1
    case "CLOB" -> 2005
    case "BLOB" -> 2004
    case "DATE" -> 91
    case "TIME" -> 92
    case "TIMESTAMP" -> 93
    case "BOOLEAN" -> 16
    case "XML" -> 2009
    else -> 12
}
---
{
    columns: payload map (row) -> do {
        var ti = parseTypeInfo(row.TYPE_INFO default "VARCHAR(255)")
        ---
        {
            catalog: null,
            schema: "APP",
            "table-name": row.TABLENAME,
            "column-name": row.COLUMNNAME,
            "data-type": mapDataType(ti.typeName),
            "type-name": ti.typeName,
            "column-size": ti.colSize,
            nullable: ti.nullable,
            "default-value": null,
            remarks: null,
            "ordinal-position": row.COLUMNNUMBER,
            "is-auto-increment": row.IS_AUTOINCREMENT == "YES"
        }
    }
}]]></ee:set-payload>
            </ee:message>
        </ee:transform>
        <error-handler ref="api-error-handler"/>
    </flow>

    <!-- GET /metadata/primary-keys -->
    <flow name="get:\metadata\primary-keys:clouderby-api-config">
        <flow-ref name="validate-session"/>
        <set-variable variableName="tableName" value="#[upper(attributes.queryParams.table default '')]"/>
        <choice>
            <when expression="#[vars.tableName == '']">
                <set-variable variableName="httpStatus" value="400"/>
                <ee:transform>
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{error: "Table name is required"}]]></ee:set-payload>
                    </ee:message>
                </ee:transform>
            </when>
            <otherwise>
                <java:invoke-static class="com.muledev.server.SqlExecutor" method="executeMetadataQuery(String, String, List)" target="pkInfo">
                    <java:args>#[{
                        sessionId: vars.sessionId,
                        sql: "SELECT C.CONSTRAINTNAME AS PK_NAME, CAST(CG.DESCRIPTOR AS VARCHAR(512)) AS DESCRIPTOR FROM SYS.SYSCONSTRAINTS C JOIN SYS.SYSKEYS K ON C.CONSTRAINTID = K.CONSTRAINTID JOIN SYS.SYSCONGLOMERATES CG ON K.CONGLOMERATEID = CG.CONGLOMERATEID JOIN SYS.SYSTABLES T ON C.TABLEID = T.TABLEID JOIN SYS.SYSSCHEMAS S ON T.SCHEMAID = S.SCHEMAID WHERE C.TYPE = 'P' AND S.SCHEMANAME = 'APP' AND T.TABLENAME = ?",
                        params: [vars.tableName]
                    }]</java:args>
                </java:invoke-static>
                <java:invoke-static class="com.muledev.server.SqlExecutor" method="executeMetadataQuery(String, String, List)">
                    <java:args>#[{
                        sessionId: vars.sessionId,
                        sql: "SELECT COLUMNNAME, COLUMNNUMBER FROM SYS.SYSCOLUMNS WHERE REFERENCEID = (SELECT TABLEID FROM SYS.SYSTABLES T JOIN SYS.SYSSCHEMAS S ON T.SCHEMAID = S.SCHEMAID WHERE S.SCHEMANAME = 'APP' AND T.TABLENAME = ?) ORDER BY COLUMNNUMBER",
                        params: [vars.tableName]
                    }]</java:args>
                </java:invoke-static>
                <ee:transform doc:name="Build PK response">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
var pkInfo = vars.pkInfo
var allCols = payload
var descriptor = if (sizeOf(pkInfo) > 0) (pkInfo[0].DESCRIPTOR default "") else ""
var pkName = if (sizeOf(pkInfo) > 0) pkInfo[0].PK_NAME else null
var openIdx = (descriptor find "(")[0] default -1
var closeIdx = (descriptor find ")")[0] default -1
var colNumsStr = if (openIdx >= 0 and closeIdx > openIdx) (descriptor[(openIdx + 1) to (closeIdx - 1)]) else ""
var colNums = if (colNumsStr != "") ((splitBy(colNumsStr, ",")) map (trim($) as Number)) else []
---
{
    "primary-keys": colNums map (num, idx) -> {
        catalog: null,
        schema: "APP",
        "table-name": vars.tableName,
        "column-name": (allCols filter ($.COLUMNNUMBER == num))[0].COLUMNNAME default "",
        "key-seq": idx + 1,
        "pk-name": pkName
    }
}]]></ee:set-payload>
                    </ee:message>
                </ee:transform>
            </otherwise>
        </choice>
        <error-handler ref="api-error-handler"/>
    </flow>

