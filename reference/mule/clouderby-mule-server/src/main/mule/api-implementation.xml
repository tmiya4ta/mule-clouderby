        </ee:transform>
    </flow>

    <!-- POST /sessions -->
    <flow name="post:\sessions:application\json:clouderby-api-config">
        <choice>
            <when expression="#[payload.user == '${clouderby.user}' and payload.password == '${clouderby.password}']">
                <java:invoke-static class="com.muledev.server.SqlExecutor" method="createSession(String)">
                    <java:args>#[{database: payload.database default 'default'}]</java:args>
                </java:invoke-static>
                <logger level="INFO" message='#["[CLOUDERBY] Session opened: " ++ payload."session-id"]'/>
                <ee:transform doc:name="Session created">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
payload]]></ee:set-payload>
                    </ee:message>
                </ee:transform>
            </when>
            <otherwise>
                <set-variable variableName="httpStatus" value="401"/>
                <ee:transform doc:name="Auth failed">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{error: "Authentication failed"}]]></ee:set-payload>
                    </ee:message>
                </ee:transform>
            </otherwise>
        </choice>
    </flow>

