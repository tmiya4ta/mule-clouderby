    <!-- POST /auth/change-password -->
    <flow name="post:\auth\change-password:application\json:clouderby-api-config">
        <set-variable variableName="httpStatus" value="501"/>
        <ee:transform>
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{error: "Password change not supported (property-based authentication)"}]]></ee:set-payload>
            </ee:message>
        </ee:transform>
    </flow>

    <!-- ============================================ -->
    <!-- Additional Non-API Endpoints                -->
    <!-- ============================================ -->

    <!-- GET / - Serve UI -->
    <flow name="ui-index-flow">
        <http:listener doc:name="GET /" config-ref="HTTP_Listener_config" path="/" allowedMethods="GET"/>
        <parse-template doc:name="Parse Template" location="static/index.html"/>
        <set-payload value="#[payload]" doc:name="Set Payload" mimeType="text/html"/>
    </flow>

    <!-- GET /api/db/tables - List all tables (for UI) -->
    <flow name="db-tables-flow">
        <http:listener doc:name="GET /api/db/tables" config-ref="HTTP_Listener_config" path="/api/db/tables" allowedMethods="GET"/>
        <java:invoke-static class="com.muledev.server.SqlExecutor" method="executeSystemQuery(String, List)">
            <java:args>#[{
                sql: "SELECT T.TABLENAME AS NAME FROM SYS.SYSTABLES T JOIN SYS.SYSSCHEMAS S ON T.SCHEMAID = S.SCHEMAID WHERE S.SCHEMANAME = 'APP' AND T.TABLETYPE = 'T' ORDER BY T.TABLENAME",
                params: null
            }]</java:args>
        </java:invoke-static>
        <ee:transform doc:name="Transform">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    tables: payload map $.NAME,
    count: sizeOf(payload)
}]]></ee:set-payload>
            </ee:message>
        </ee:transform>
        <error-handler ref="global-error-handler"/>
    </flow>

    <!-- GET /api/completions - Get SQL completion candidates (for UI) -->
    <flow name="completions-flow">
        <http:listener doc:name="GET /api/completions" config-ref="HTTP_Listener_config" path="/api/completions" allowedMethods="GET"/>
        <java:invoke-static class="com.muledev.server.SqlExecutor" method="executeSystemQuery(String, List)">
            <java:args>#[{
                sql: "SELECT T.TABLENAME AS NAME FROM SYS.SYSTABLES T JOIN SYS.SYSSCHEMAS S ON T.SCHEMAID = S.SCHEMAID WHERE S.SCHEMANAME = 'APP' AND T.TABLETYPE = 'T' ORDER BY T.TABLENAME",
                params: null
            }]</java:args>
        </java:invoke-static>
        <ee:transform doc:name="Build completions">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
var sqlKeywords = ["SELECT", "FROM", "WHERE", "INSERT", "INTO", "VALUES", "UPDATE", "SET", "DELETE",
                   "CREATE", "TABLE", "DROP", "ALTER", "ADD", "INDEX", "JOIN", "LEFT", "RIGHT", "INNER",
                   "OUTER", "ON", "AND", "OR", "NOT", "NULL", "IS", "IN", "LIKE", "BETWEEN", "AS",
                   "ORDER", "BY", "ASC", "DESC", "GROUP", "HAVING", "FETCH", "OFFSET", "DISTINCT",
                   "COUNT", "SUM", "AVG", "MIN", "MAX", "COALESCE", "CASE", "WHEN", "THEN", "ELSE", "END",
                   "INTEGER", "VARCHAR", "DOUBLE", "DECIMAL", "BOOLEAN", "DATE", "TIMESTAMP", "CLOB", "BLOB",
                   "PRIMARY", "KEY", "GENERATED", "ALWAYS", "IDENTITY", "UNIQUE", "DEFAULT"]
---
{
    keywords: sqlKeywords,
    tables: payload map $.NAME,
    columns: []
}]]></ee:set-payload>
            </ee:message>
        </ee:transform>
        <error-handler ref="global-error-handler"/>
    </flow>

</mule>
